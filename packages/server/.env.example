PIER_PORT=8420
PIER_HOST=0.0.0.0
PIER_DATA_DIR=./data
PIER_MANIFEST_PATH=./manifest.yaml

# Set EXACTLY ONE of PIER_MASTER_KEY or PIER_MASTER_KEY_FILE:

# Inline (fine for dev; leaks via `ps`, `docker inspect`, /proc/<pid>/environ):
#   64 hex chars = 32 bytes. Generate: openssl rand -hex 32
PIER_MASTER_KEY=change-me-openssl-rand-hex-32-goes-here-must-be-64-characters-long

# File-backed (recommended for production — works with Docker secrets,
# K8s projected volumes, Vault Agent renders, etc.):
# PIER_MASTER_KEY_FILE=/run/secrets/pier-master-key

# Comma-separated device tokens. Each machine gets one. Generate: openssl rand -hex 24
PIER_TOKENS=

# Optional: path to built UI bundle. Defaults to ../ui/dist relative to cwd.
# PIER_UI_DIR=
