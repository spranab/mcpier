{
  "name": "mcpier",
  "version": "0.1.3",
  "description": "pier — CLI for mcpier, a self-hosted MCP control plane. Install, sync, browse, backup MCP servers from your homelab.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cli",
    "homelab",
    "self-hosted",
    "claude",
    "ai-tools"
  ],
  "license": "MIT",
  "author": "spranab",
  "homepage": "https://github.com/spranab/mcpier",
  "repository": {
    "type": "git",
    "url": "https://github.com/spranab/mcpier.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/spranab/mcpier/issues"
  },
  "type": "module",
  "bin": {
    "pier": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "commander": "^12.1.0",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@mcpier/shared": "*",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
